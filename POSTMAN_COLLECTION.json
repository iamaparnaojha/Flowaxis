{
  "info": {
    "name": "FlowAxis API",
    "description": "Complete API collection for FlowAxis — Project & Task Management by Aparna Ojha",
    "version": "1.0.0",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "variable": [
    { "key": "baseUrl", "value": "http://localhost:8080/api/v1", "type": "string" },
    { "key": "accessToken", "value": "", "type": "string" },
    { "key": "projectId", "value": "", "type": "string" },
    { "key": "taskId", "value": "", "type": "string" },
    { "key": "userId", "value": "", "type": "string" }
  ],
  "item": [
    {
      "name": "Auth",
      "item": [
        {
          "name": "Register",
          "request": {
            "method": "POST",
            "url": "{{baseUrl}}/auth/register",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"name\": \"Aparna Ojha\",\n  \"email\": \"aparna@flowaxis.dev\",\n  \"password\": \"Secure@123\"\n}"
            }
          }
        },
        {
          "name": "Login",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "const res = pm.response.json();",
                  "if (res.data?.accessToken) {",
                  "  pm.collectionVariables.set('accessToken', res.data.accessToken);",
                  "  console.log('Access token saved.');",
                  "}"
                ]
              }
            }
          ],
          "request": {
            "method": "POST",
            "url": "{{baseUrl}}/auth/login",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"email\": \"admin@flowaxis.dev\",\n  \"password\": \"Admin@flowaxis1\"\n}"
            }
          }
        },
        {
          "name": "Refresh Token",
          "request": {
            "method": "POST",
            "url": "{{baseUrl}}/auth/refresh",
            "header": []
          }
        },
        {
          "name": "Logout",
          "request": {
            "method": "POST",
            "url": "{{baseUrl}}/auth/logout",
            "header": [{ "key": "Authorization", "value": "Bearer {{accessToken}}" }]
          }
        }
      ]
    },
    {
      "name": "Users",
      "item": [
        {
          "name": "Get My Profile",
          "request": {
            "method": "GET",
            "url": "{{baseUrl}}/users/me",
            "header": [{ "key": "Authorization", "value": "Bearer {{accessToken}}" }]
          }
        },
        {
          "name": "Update My Profile",
          "request": {
            "method": "PATCH",
            "url": "{{baseUrl}}/users/me",
            "header": [
              { "key": "Authorization", "value": "Bearer {{accessToken}}" },
              { "key": "Content-Type", "value": "application/json" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"name\": \"Aparna Ojha Updated\"\n}"
            }
          }
        },
        {
          "name": "List All Users (Admin)",
          "request": {
            "method": "GET",
            "url": {
              "raw": "{{baseUrl}}/users?page=1&limit=20",
              "query": [
                { "key": "page", "value": "1" },
                { "key": "limit", "value": "20" }
              ]
            },
            "header": [{ "key": "Authorization", "value": "Bearer {{accessToken}}" }]
          }
        },
        {
          "name": "Delete User (Admin)",
          "request": {
            "method": "DELETE",
            "url": "{{baseUrl}}/users/{{userId}}",
            "header": [{ "key": "Authorization", "value": "Bearer {{accessToken}}" }]
          }
        }
      ]
    },
    {
      "name": "Projects",
      "item": [
        {
          "name": "Create Project",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "const res = pm.response.json();",
                  "if (res.data?.project?._id) {",
                  "  pm.collectionVariables.set('projectId', res.data.project._id);",
                  "  console.log('Project ID saved:', res.data.project._id);",
                  "}"
                ]
              }
            }
          ],
          "request": {
            "method": "POST",
            "url": "{{baseUrl}}/projects",
            "header": [
              { "key": "Authorization", "value": "Bearer {{accessToken}}" },
              { "key": "Content-Type", "value": "application/json" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"name\": \"My First Project\",\n  \"description\": \"A test project created via Postman.\",\n  \"tags\": [\"test\", \"api\"],\n  \"dueDate\": \"2025-12-31T00:00:00.000Z\"\n}"
            }
          }
        },
        {
          "name": "List My Projects",
          "request": {
            "method": "GET",
            "url": "{{baseUrl}}/projects",
            "header": [{ "key": "Authorization", "value": "Bearer {{accessToken}}" }]
          }
        },
        {
          "name": "Get Project by ID",
          "request": {
            "method": "GET",
            "url": "{{baseUrl}}/projects/{{projectId}}",
            "header": [{ "key": "Authorization", "value": "Bearer {{accessToken}}" }]
          }
        },
        {
          "name": "Update Project",
          "request": {
            "method": "PATCH",
            "url": "{{baseUrl}}/projects/{{projectId}}",
            "header": [
              { "key": "Authorization", "value": "Bearer {{accessToken}}" },
              { "key": "Content-Type", "value": "application/json" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"name\": \"Updated Project Name\",\n  \"description\": \"Updated description.\"\n}"
            }
          }
        },
        {
          "name": "Transition Project Status",
          "request": {
            "method": "PATCH",
            "url": "{{baseUrl}}/projects/{{projectId}}/status",
            "header": [
              { "key": "Authorization", "value": "Bearer {{accessToken}}" },
              { "key": "Content-Type", "value": "application/json" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"status\": \"active\"\n}"
            }
          }
        },
        {
          "name": "Add Member",
          "request": {
            "method": "POST",
            "url": "{{baseUrl}}/projects/{{projectId}}/members",
            "header": [
              { "key": "Authorization", "value": "Bearer {{accessToken}}" },
              { "key": "Content-Type", "value": "application/json" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"userId\": \"{{userId}}\",\n  \"role\": \"editor\"\n}"
            }
          }
        },
        {
          "name": "Remove Member",
          "request": {
            "method": "DELETE",
            "url": "{{baseUrl}}/projects/{{projectId}}/members/{{userId}}",
            "header": [{ "key": "Authorization", "value": "Bearer {{accessToken}}" }]
          }
        },
        {
          "name": "Delete Project",
          "request": {
            "method": "DELETE",
            "url": "{{baseUrl}}/projects/{{projectId}}",
            "header": [{ "key": "Authorization", "value": "Bearer {{accessToken}}" }]
          }
        }
      ]
    },
    {
      "name": "Tasks",
      "item": [
        {
          "name": "Create Task",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "const res = pm.response.json();",
                  "if (res.data?.task?._id) {",
                  "  pm.collectionVariables.set('taskId', res.data.task._id);",
                  "  console.log('Task ID saved:', res.data.task._id);",
                  "}"
                ]
              }
            }
          ],
          "request": {
            "method": "POST",
            "url": "{{baseUrl}}/projects/{{projectId}}/tasks",
            "header": [
              { "key": "Authorization", "value": "Bearer {{accessToken}}" },
              { "key": "Content-Type", "value": "application/json" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"title\": \"Implement login flow\",\n  \"description\": \"Handle JWT auth on the frontend.\",\n  \"priority\": \"high\",\n  \"dueDate\": \"2025-11-30T00:00:00.000Z\"\n}"
            }
          }
        },
        {
          "name": "List Project Tasks",
          "request": {
            "method": "GET",
            "url": {
              "raw": "{{baseUrl}}/projects/{{projectId}}/tasks?status=todo",
              "query": [{ "key": "status", "value": "todo" }]
            },
            "header": [{ "key": "Authorization", "value": "Bearer {{accessToken}}" }]
          }
        },
        {
          "name": "Get Task by ID",
          "request": {
            "method": "GET",
            "url": "{{baseUrl}}/projects/{{projectId}}/tasks/{{taskId}}",
            "header": [{ "key": "Authorization", "value": "Bearer {{accessToken}}" }]
          }
        },
        {
          "name": "Update Task",
          "request": {
            "method": "PATCH",
            "url": "{{baseUrl}}/projects/{{projectId}}/tasks/{{taskId}}",
            "header": [
              { "key": "Authorization", "value": "Bearer {{accessToken}}" },
              { "key": "Content-Type", "value": "application/json" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"title\": \"Updated task title\",\n  \"priority\": \"critical\"\n}"
            }
          }
        },
        {
          "name": "Transition Task Status",
          "request": {
            "method": "PATCH",
            "url": "{{baseUrl}}/projects/{{projectId}}/tasks/{{taskId}}/status",
            "header": [
              { "key": "Authorization", "value": "Bearer {{accessToken}}" },
              { "key": "Content-Type", "value": "application/json" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"status\": \"in_progress\"\n}"
            }
          }
        },
        {
          "name": "Delete Task",
          "request": {
            "method": "DELETE",
            "url": "{{baseUrl}}/projects/{{projectId}}/tasks/{{taskId}}",
            "header": [{ "key": "Authorization", "value": "Bearer {{accessToken}}" }]
          }
        }
      ]
    }
  ]
}
